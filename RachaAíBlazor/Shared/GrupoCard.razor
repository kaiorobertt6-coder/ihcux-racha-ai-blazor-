@* Assumindo que seu namespace principal seja RachaAi *@
@using RachaAíBlazor.Models

<div class="card mb-3 shadow-sm border-0 bg-white">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div class="d-flex flex-column">
            <span class="badge bg-light text-dark border mb-2 align-self-start">@Grupo.Categoria</span>
            @* Nome do grupo em negrito [cite: 51] *@
            <h5 class="card-title fw-bold mb-0">@Grupo.Nome</h5>
        </div>
        <div>
            @* Uso de cores para indicar dívida ou crédito [cite: 54] *@
            <span class="@(Grupo.NoVermelho ? "text-danger" : "text-success") fw-bold fs-5">
                R$ @Grupo.ValorPendente.ToString("N2")
            </span>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Grupo Grupo { get; set; } = new Grupo();
}