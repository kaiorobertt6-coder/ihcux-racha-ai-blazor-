@page "/dashboard"
@using RachaAíBlazor.Models

<div class="container mt-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Olá, Kaio! 👋</h2>
        <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold">
            Adicionar Novo Gasto
        </button>
    </div>

    <div class="row mb-5 text-center">
        <div class="col-12 col-md-4 mb-3">
            <div class="card bg-primary text-white shadow-sm p-4 h-100 border-0 rounded-4">
                <h6 class="text-white-50 mb-2">Saldo Geral</h6>
                <h3 class="fw-bold mb-0">R$ @SaldoGeral.ToString("N2")</h3>
            </div>
        </div>
        <div class="col-12 col-md-4 mb-3">
            <div class="card shadow-sm p-4 h-100 border-0 rounded-4">
                <h6 class="text-muted mb-2">A Receber</h6>
                <h3 class="text-success fw-bold mb-0">R$ @TotalReceber.ToString("N2")</h3>
            </div>
        </div>
        <div class="col-12 col-md-4 mb-3">
            <div class="card shadow-sm p-4 h-100 border-0 rounded-4">
                <h6 class="text-muted mb-2">A Pagar</h6>
                <h3 class="text-danger fw-bold mb-0">R$ @TotalPagar.ToString("N2")</h3>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <input type="text" 
               class="form-control rounded-pill px-4 py-2 bg-light border-0 shadow-sm" 
               placeholder="Buscar grupo ou categoria..." 
               @bind-value="TermoBusca" 
               @bind-value:event="oninput" />
    </div>

    <h6 class="text-muted mb-3 fw-bold">SEUS GRUPOS ATIVOS</h6>

    @if (GruposFiltrados == null || !GruposFiltrados.Any())
    {
        <div class="alert alert-light text-center border p-5 rounded-4 shadow-sm" role="alert">
            <h5 class="text-muted mb-0">Você ainda não participa de nenhum grupo. Que tal criar um?</h5>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var grupo in GruposFiltrados)
            {
                <div class="col-12 col-md-6">
                    <GrupoCard Grupo="grupo" />
                </div>
            }
        </div>
    }
</div>

@code {
    // Lista estática de grupos [cite: 61]
    private List<Grupo> Grupos { get; set; } = new();
    
    // Propriedade para o filtro
    private string TermoBusca { get; set; } = string.Empty;

    // Lógica do filtro de busca [cite: 73]
    private IEnumerable<Grupo> GruposFiltrados =>
        string.IsNullOrWhiteSpace(TermoBusca)
            ? Grupos
            : Grupos.Where(g => g.Nome.Contains(TermoBusca, StringComparison.OrdinalIgnoreCase) ||
                                g.Categoria.Contains(TermoBusca, StringComparison.OrdinalIgnoreCase));

    // Cálculos dinâmicos para os cards do topo
    private decimal TotalPagar => Grupos.Where(g => g.NoVermelho).Sum(g => g.ValorPendente);
    private decimal TotalReceber => Grupos.Where(g => !g.NoVermelho).Sum(g => g.ValorPendente);
    private decimal SaldoGeral => TotalReceber - TotalPagar;

    protected override void OnInitialized()
    {
        // Populando a tela com os dados do exercício
        Grupos = new List<Grupo>
        {
            new Grupo { Nome = "República Central", Categoria = "Casa", ValorPendente = 450.50m, NoVermelho = true },
            new Grupo { Nome = "Churrasco de Domingo", Categoria = "Lazer", ValorPendente = 85.00m, NoVermelho = false },
            new Grupo { Nome = "Viagem Floripa", Categoria = "Lazer", ValorPendente = 1200.00m, NoVermelho = false },
            new Grupo { Nome = "Netflix & Internet", Categoria = "Contas", ValorPendente = 35.90m, NoVermelho = true }
        };
    }
}